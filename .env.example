# geny-avatar — environment variables
#
# Copy to `.env.local` (which is git-ignored) and fill in the keys for
# whichever AI providers you want to use. Missing keys disable just that
# provider — the app still builds and runs without any of them.
#
# All AI provider calls happen server-side in /api/ai/* route handlers.
# Keys are NEVER exposed to the client bundle.

# Google Gemini ("Nano Banana") — required for the Gemini provider.
# Get one at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# OpenAI gpt-image-2 — required for the OpenAI provider.
# Get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Replicate — used by the SDXL + ControlNet workflow that lands in
# Sprint 3.2. Optional today; provider returns "unavailable" without it.
# Get one at https://replicate.com/account/api-tokens
REPLICATE_API_TOKEN=

# fal.ai — required for the FLUX.2 [edit] provider. Cheaper escape
# hatch from gpt-image-2 for bulk fan-out (~10× lower per-image at
# Schnell tier) and stronger identity preservation across multiple
# reference images.
# Get one at https://fal.ai/dashboard/keys
FAL_KEY=
