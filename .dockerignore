# Build context exclusions for Docker. Mirrors .gitignore for the most
# part, plus a few things we keep in git but don't want in the image.

# dependencies (re-installed in-stage from package.json + lockfile)
node_modules
.pnpm-store

# build outputs (reproduced fresh in builder stage)
.next
out
build
dist
*.tsbuildinfo

# generated by scripts/sync-vendor.mjs — runs again inside the image
public/samples
public/runtime

# misc / dev clutter we never want in the image
.git
.github
.vscode
.idea
.DS_Store
Thumbs.db
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# local env (image gets its config from compose env: vars)
.env
.env.local
.env.*.local

# docs add ~5MB and aren't read at runtime
docs

# certs / pem
*.pem
